# ClickHouse bağlantı ayarları
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DATABASE=telemetry
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# EMQX MQTT broker ayarları
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=dashboard-api
MQTT_TOPIC_PREFIX=telemetry

# HTTP sunucu ayarları
SERVER_PORT=8080

# ClickHouse'dan veri çekme aralığı (ms)
POLL_INTERVAL_MS=1000
